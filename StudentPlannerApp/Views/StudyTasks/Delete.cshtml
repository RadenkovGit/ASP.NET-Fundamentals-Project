@model StudyTask
@{
    ViewData["Title"] = "Delete Task";
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h1 class="h3 text-danger">Delete Task</h1>
        <p>Are you sure you want to delete this task?</p>

        <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Title:</strong> @Model.Title</li>
            <li class="list-group-item"><strong>Subject:</strong> @Model.Subject?.Name</li>
            <li class="list-group-item"><strong>Due Date:</strong> @Model.Deadline.ToShortDateString()</li>
        </ul>

        <form asp-action="Delete" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
